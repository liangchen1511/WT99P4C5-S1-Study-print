# Release profile — merge with sdkconfig.defaults:
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.release" build

# Log
CONFIG_LOG_DEFAULT_LEVEL_WARN=y
CONFIG_LOG_DEFAULT_LEVEL=2

# Bluetooth off (WiFi uses ESP-Hosted SDIO)
CONFIG_BT_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=n
CONFIG_ESP_HOSTED_ENABLE_BT_NIMBLE=n

# LVGL fonts — keep sizes used by Music UI + Brookesia
CONFIG_LV_FONT_MONTSERRAT_8=n
CONFIG_LV_FONT_MONTSERRAT_10=n
CONFIG_LV_FONT_MONTSERRAT_12=n
CONFIG_LV_FONT_MONTSERRAT_18=n
CONFIG_LV_FONT_MONTSERRAT_20=n
CONFIG_LV_FONT_MONTSERRAT_24=n
CONFIG_LV_FONT_MONTSERRAT_26=n
CONFIG_LV_FONT_MONTSERRAT_28=n
CONFIG_LV_FONT_MONTSERRAT_30=n
CONFIG_LV_FONT_MONTSERRAT_34=n
CONFIG_LV_FONT_MONTSERRAT_36=n
CONFIG_LV_FONT_MONTSERRAT_38=n
CONFIG_LV_FONT_MONTSERRAT_40=n
CONFIG_LV_FONT_MONTSERRAT_42=n
CONFIG_LV_FONT_MONTSERRAT_44=n
CONFIG_LV_FONT_MONTSERRAT_46=n
CONFIG_LV_FONT_MONTSERRAT_48=n
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_22=y
CONFIG_LV_FONT_MONTSERRAT_32=y

# LVGL demo/debug off
CONFIG_LV_USE_MONKEY=n
CONFIG_LV_USE_DEMO_WIDGETS=n
CONFIG_LV_USE_DEMO_BENCHMARK=n
CONFIG_LV_USE_DEMO_STRESS=n

# Size over speed for release flash budget
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_OPTIMIZATION_PERF=n

# Runtime stats off
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=n
CONFIG_FREERTOS_VTASKLIST_INCLUDE_COREID=n

# UART printer boot test off
CONFIG_UART_ESC_POS_BOOT_TEST=n

# AI detect models off
CONFIG_HUMAN_FACE_DETECT_MODEL_IN_FLASH_RODATA=n
CONFIG_PEDESTRIAN_DETECT_MODEL_IN_FLASH_RODATA=n

# RAM tuning
CONFIG_LV_LAYER_SIMPLE_BUF_SIZE=51200
CONFIG_LV_IMG_CACHE_DEF_SIZE=10
CONFIG_FREERTOS_TASK_CREATE_ALLOW_EXT_MEM=y

# Network
CONFIG_LWIP_TCP_RECVMBOX_SIZE=16
