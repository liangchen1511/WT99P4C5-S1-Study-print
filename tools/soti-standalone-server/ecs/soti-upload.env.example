# 复制到 ECS：sudo cp soti-upload.env.example /etc/soti-upload.env && sudo chmod 600 /etc/soti-upload.env
# 编辑填入真实 Key 与 ep- 接入点 ID 后：sudo systemctl restart soti-upload

LISTEN=127.0.0.1
PORT=3000

# 与固件 soti_config.h 中 SOTI_R2_UPLOAD_TOKEN 一致
UPLOAD_TOKEN=esp32souti

# 火山方舟控制台 → API Key 管理
DOUBAO_API_KEY=

# 火山方舟控制台 → 推理接入点 → 复制「接入点 ID」（必须以 ep- 开头，不要用 doubao-xxx 公开名）
DOUBAO_MODEL=ep-xxxxxxxxxxxxxxxx

# 一般无需改
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MAX_TOKENS=4096
SOTI_BINARIZE=1

# 家长控制台（/parent/）
PARENT_PASSWORD=parent2025
PARENT_DEVICE_CODES=WT99-DEMO-01
# PARENT_DATA_DIR=/var/lib/soti-parent
# PARENT_MAX_HISTORY=500
